{
	admin 0.0.0.0:2019
	servers {
		metrics
	}
}

# HTTPS — Let's Encrypt cert via DuckDNS DNS-01
{$DUCKDNS_SUBDOMAIN}.duckdns.org {
	tls {
		dns duckdns {$DUCKDNS_TOKEN}
	}

	handle /jellyfin/* {
		reverse_proxy jellyfin:8096
	}

	redir /qbit /qbit/ 302
	handle_path /qbit/* {
		reverse_proxy qbittorrent:8080
	}

	handle /sonarr/* {
		reverse_proxy sonarr:8989
	}

	handle /radarr/* {
		reverse_proxy radarr:7878
	}

	handle /prowlarr/* {
		reverse_proxy warp:9696
	}

	handle /bazarr/* {
		reverse_proxy bazarr:6767
	}

	# OpenClaw — catch-all (WebSocket + API)
	handle {
		reverse_proxy openclaw:18789
	}
}
