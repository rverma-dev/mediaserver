{
	admin 0.0.0.0:2019
	servers {
		metrics
	}
}

# HTTPS — Let's Encrypt cert via DuckDNS DNS-01
{$DUCKDNS_SUBDOMAIN}.duckdns.org {
	tls {
		dns duckdns {$DUCKDNS_TOKEN}
	}

	handle /jellyfin/* {
		reverse_proxy 172.20.0.4:8096
	}

	redir /qbit /qbit/ 302
	handle_path /qbit/* {
		reverse_proxy 172.20.0.5:8080
	}

	handle /sonarr/* {
		reverse_proxy 172.20.0.6:8989
	}

	handle /radarr/* {
		reverse_proxy 172.20.0.7:7878
	}

	handle /prowlarr/* {
		reverse_proxy 172.20.0.3:9696
	}

	handle /bazarr/* {
		reverse_proxy 172.20.0.8:6767
	}

	handle /seerr/* {
		reverse_proxy 127.0.0.1:5055
	}

	# OpenClaw — native service on localhost
	handle {
		reverse_proxy 127.0.0.1:18789
	}
}
