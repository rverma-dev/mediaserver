# System
PUID=1000
PGID=1000
TZ=Asia/Kolkata
MEDIASERVER_ROOT=/home/pi/mediaserver

# External HDD. Mount at /mnt/hdd; contains downloads, media, immich/library
# HDD_MOUNT_PATH=/mnt/hdd

# *arr API keys (init-config injects into configs)
SONARR_API_KEY=
RADARR_API_KEY=
PROWLARR_API_KEY=
BAZARR_API_KEY=

# Bazarr extras (flask session secret; generate with: openssl rand -hex 32)
FLASK_SECRET_KEY=

# OpenSubtitles.com (optional, for opensubtitlescom provider)
OPENSUBTITLES_USERNAME=
OPENSUBTITLES_PASSWORD=

# Plex (optional, for Bazarr Plex integration)
PLEX_ENCRYPTION_KEY=

# DuckDNS (HTTPS via Caddy)
DUCKDNS_TOKEN=
DUCKDNS_SUBDOMAIN=

# Optional: enforce Pi LAN IP (matches DuckDNS mapping). Set to e.g. 192.168.68.60
# to configure static IP via dhcpcd. Requires PI_LAN_GW (router IP, e.g. 192.168.68.1).
# PI_LAN_IP=
# PI_LAN_GW=

# Cursor Agent CLI (terminal agent)
CURSOR_API_KEY=

# OpenClaw runs from ~/openclaw with its own config (see ~/openclaw/README.md)

# Grafana Cloud (optional — set GCLOUD_RW_API_KEY to enable Alloy install script)
GCLOUD_RW_API_KEY=
GCLOUD_HOSTED_METRICS_ID=2992798
GCLOUD_HOSTED_METRICS_URL=https://prometheus-prod-43-prod-ap-south-1.grafana.net/api/prom/push
GCLOUD_HOSTED_LOGS_ID=1492074
GCLOUD_HOSTED_LOGS_URL=https://logs-prod-028.grafana.net/loki/api/v1/push
GCLOUD_FM_URL=https://fleet-management-prod-018.grafana.net
GCLOUD_FM_POLL_FREQUENCY=60s
GCLOUD_FM_HOSTED_ID=1534285
