# System
PUID=1000
PGID=1000
TZ=Asia/Kolkata
MEDIASERVER_ROOT=/opt/mediaserver

# *arr API keys (init-config injects into configs)
SONARR_API_KEY=
RADARR_API_KEY=
PROWLARR_API_KEY=
BAZARR_API_KEY=

# DuckDNS (HTTPS)
DUCKDNS_TOKEN=
DUCKDNS_SUBDOMAIN=

# OpenClaw
OPENCLAW_GATEWAY_TOKEN=
GOOGLE_API_KEY=
GEMINI_API_KEY=
# Override image (default: ghcr.io/openclaw/openclaw:latest; use ghcr.io/OWNER/openclaw:latest if self-built)
# OPENCLAW_IMAGE=

# Grafana Cloud (optional — set GCLOUD_RW_API_KEY to enable Alloy install script)
GCLOUD_RW_API_KEY=
GCLOUD_HOSTED_METRICS_ID=2992798
GCLOUD_HOSTED_METRICS_URL=https://prometheus-prod-43-prod-ap-south-1.grafana.net/api/prom/push
GCLOUD_HOSTED_LOGS_ID=1492074
GCLOUD_HOSTED_LOGS_URL=https://logs-prod-028.grafana.net/loki/api/v1/push
GCLOUD_FM_URL=https://fleet-management-prod-018.grafana.net
GCLOUD_FM_POLL_FREQUENCY=60s
GCLOUD_FM_HOSTED_ID=1534285

# Override Caddy image (default: ghcr.io/rverma-dev/caddy-duckdns:latest)
# CADDY_IMAGE=

# Service API Keys (inter-service communication)
SONARR_API_KEY=
RADARR_API_KEY=
PROWLARR_API_KEY=
BAZARR_API_KEY=
