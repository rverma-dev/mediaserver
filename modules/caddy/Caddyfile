{
	admin 0.0.0.0:2019
	servers {
		metrics
	}
}

# HTTPS — DuckDNS domain only, OpenClaw gateway catch-all (runs in ~/openclaw)
{$DUCKDNS_SUBDOMAIN}.duckdns.org {
	tls {
		dns duckdns {$DUCKDNS_TOKEN}
	}

	redir /jellyfin /jellyfin/ 302
	handle /jellyfin/* {
		@cors_preflight method OPTIONS
		handle @cors_preflight {
			header Access-Control-Allow-Origin "https://dev.chaksh.xyz"
			header Access-Control-Allow-Methods "GET, HEAD, OPTIONS"
			header Access-Control-Allow-Headers "*"
			header Access-Control-Max-Age "3600"
			respond "" 204
		}
		header Access-Control-Allow-Origin "https://dev.chaksh.xyz"
		reverse_proxy 127.0.0.1:8096 {
			header_down -Access-Control-Allow-Origin
			header_down -Access-Control-Allow-Methods
			header_down -Access-Control-Allow-Headers
		}
	}

	redir /qbit /qbit/ 302
	handle_path /qbit/* {
		reverse_proxy 127.0.0.1:8080
	}

	redir /sonarr /sonarr/ 302
	handle /sonarr/* {
		reverse_proxy 127.0.0.1:8989
	}

	redir /radarr /radarr/ 302
	handle /radarr/* {
		reverse_proxy 127.0.0.1:7878
	}

	redir /prowlarr /prowlarr/ 302
	handle /prowlarr/* {
		reverse_proxy 127.0.0.1:9696
	}

	redir /bazarr /bazarr/ 302
	handle /bazarr/* {
		reverse_proxy 127.0.0.1:6767
	}

	# Immich mobile OAuth callback — Google redirects here (HTTPS), we bounce to app deep link.
	handle /photos/oauth-callback* {
		redir * "app.immich:///oauth-callback?{query}" 302
	}

	# Immich — /photos/* strips the prefix (SvelteKit router sees /photos/... from the browser).
	# All other Immich SvelteKit routes are proxied as-is (no stripping needed).
	# /_app/* and /api/* are referenced by the SPA without the /photos prefix.
	redir /photos /photos/ 302
	handle_path /photos/* {
		reverse_proxy 127.0.0.1:3001
	}
	@immich_routes path /albums* /people* /explore* /archive* /favorites* /map* /memory* /tags* /user-settings* /admin/* /auth/* /share/* /trash* /shared-links*
	handle @immich_routes {
		reverse_proxy 127.0.0.1:3001
	}
	handle /_app/* {
		reverse_proxy 127.0.0.1:3001
	}
	handle /api/* {
		reverse_proxy 127.0.0.1:3001
	}

	handle {
		reverse_proxy 127.0.0.1:18789
	}
}

# HTTPS port 9443 — Seerr only (separate from OpenClaw root)
{$DUCKDNS_SUBDOMAIN}.duckdns.org:9443 {
	tls {
		dns duckdns {$DUCKDNS_TOKEN}
	}
	reverse_proxy 127.0.0.1:5055
}
